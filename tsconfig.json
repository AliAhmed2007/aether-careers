{
  "compilerOptions": {
    /* Core */
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    /* Paths & Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    /* React / Next */
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "isolatedModules": true,
    /* Type Safety */
    "strict": true,
    "skipLibCheck": true,
    /* Build Behavior */
    "noEmit": true,
    "incremental": true,
    /* Future-proofing */
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}